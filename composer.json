{
    "name": "aero/aeroapi",
    "version": "1.0.1",
    "description": "Minimalist, High-Performance PHP MVC Framework with Laravel Eloquent ORM & High-Precision API Benchmarking Suite.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.0",
        "illuminate/database": "^11.0",
        "illuminate/events": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Core\\": "core/",
            "App\\": "app/"
        },
        "files": [
            "core/helpers.php"
        ]
    },
    "authors": [
        {
            "name": "Dodhy"
        }
    ],
    "config": {
        "preferred-install": "dist",
        "sort-packages": true
    }
}
