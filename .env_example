# Application Environment
APP_DEBUG=true

# Database Configuration

# --- 1. SQLite (Default out-of-the-box, no external server required) ---
DB_DSN=sqlite:database/database.sqlite
DB_USER=
DB_PASSWORD=

# --- 2. MySQL (Uncomment to use MySQL - port 3306) ---
# DB_DSN=mysql:host=127.0.0.1;port=3306;dbname=aero_db
# DB_USER=root
# DB_PASSWORD=

# --- 3. PostgreSQL (Uncomment to use PostgreSQL - port 5432) ---
# DB_DSN=pgsql:host=127.0.0.1;port=5432;dbname=aero_db
# DB_USER=postgres
# DB_PASSWORD=secret
